GEE_SERVICE_ACCOUNT="your-account@project-id.iam.gserviceaccount.com"

# Provide exactly ONE key source (if GEE_JSON_KEY_PATH is set, it wins over the others).
# Option A (local): path to the downloaded JSON key file.
# GEE_JSON_KEY_PATH="path/to/your/key.json"

# Option B (Render / portable .env): base64 of the JSON file (recommended).
# GEE_JSON_KEY_B64="paste-base64-here"

# Option C: raw JSON in an env var (awkward for multiline keys).
# GEE_JSON_KEY_CONTENT="(single-line JSON object)"

# FastAPI
PORT=8000
