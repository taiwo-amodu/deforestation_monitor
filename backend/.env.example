GEE_SERVICE_ACCOUNT="your-account@project-id.iam.gserviceaccount.com"
# Option A (local/dev): provide the key as a file path.
GEE_JSON_KEY_PATH="path/to/your/key.json"

# Option B (Render/CI friendly): provide the key JSON as env var.
# - Prefer base64 to avoid newline escaping issues.
GEE_JSON_KEY_CONTENT="(paste the full JSON key object as a single-line string)"
# GEE_JSON_KEY_B64="base64-of-the-json-key-file"

# FastAPI
PORT=8000
